{% extends "base.html" %}

{% block title %}Мои работы{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 text-primary mb-0">Мои научные работы</h1>
    <a href="/works/create/" class="btn btn-primary">+ Добавить работу</a>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-4">
        {% if works %}
            <div class="list-group list-group-flush">
                {% for work in works %}
                    <div class="list-group-item px-0 py-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <a href="/works/{{ work.id }}/" class="fw-semibold text-decoration-none text-dark">
                                    {{ work.title }}
                                </a>
                                <div class="small text-secondary mt-1">
                                    Создано: {{ work.created_at }}<br>
                                    Обновлено: {{ work.updated_at }}
                                </div>
                            </div>

                            <div class="text-end">
                                <span class="badge text-bg-primary mb-1">{{ work.visibility }}</span><br>
                                <span class="badge text-bg-secondary mb-2">{{ work.status }}</span><br>
                                <a href="/works/{{ work.id }}/update/" class="btn btn-sm btn-outline-primary">Редактировать</a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center text-secondary py-4">
                У вас пока нет работ.
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}